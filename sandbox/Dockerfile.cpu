FROM python:3.12-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl git ca-certificates \
    nodejs npm && \
    rm -rf /var/lib/apt/lists/*

# Keep the base image thin for fast first-run local execution.
# Experiments can install heavier ML packages inside /work when they are
# actually required by the selected plan.
RUN python -m pip install --no-cache-dir --upgrade pip

# Agent runtimes
RUN npm install -g @anthropic-ai/claude-code && \
    npm install -g codex

RUN useradd -m surprisal && \
    mkdir -p /work && \
    chown -R surprisal:surprisal /work

WORKDIR /work
USER surprisal
